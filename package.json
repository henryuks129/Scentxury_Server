{
  "name": "scentxury_backend",
  "version": "1.0.0",
  "description": "Scentxury OMNI-PWA Backend - Premium Fragrance E-commerce Platform for Chi Fragrance Nigeria",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:debug": "tsx watch --inspect src/server.ts",
    "build": "tsc && tsc-alias",
    "build:clean": "rm -rf dist && tsc && tsc-alias",
    "start": "node dist/server.js",
    "start:prod": "NODE_ENV=production node dist/server.js",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:ci": "vitest run --coverage --reporter=junit --outputFile=./reports/junit.xml",
    "docker:dev": "docker-compose up --build",
    "docker:dev:tools": "docker-compose --profile dev-tools up --build",
    "docker:down": "docker-compose down",
    "docker:clean": "docker-compose down -v --rmi local",
    "docker:logs": "docker-compose logs -f api",
    "docker:shell": "docker-compose exec api sh",
    "docker:build": "docker build -t scentxury-api:latest .",
    "docker:push": "docker push scentxury-api:latest",
    "db:seed": "tsx src/scripts/seed.ts",
    "db:migrate": "tsx src/scripts/migrate.ts",
    "db:test": "tsx src/scripts/test-connection.ts",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch",
    "audit": "npm audit --audit-level=moderate",
    "audit:fix": "npm audit fix",
    "prepare": "husky install || true",
    "precommit": "npm run lint && npm run typecheck",
    "prepush": "npm run test",
    "health": "curl -s http://localhost:5000/health | jq",
    "clean": "rm -rf dist node_modules coverage reports .nyc_output"
  },
  "keywords": [
    "ecommerce",
    "fragrance",
    "pwa",
    "nigeria",
    "chi-fragrance",
    "scentxury",
    "perfume",
    "cosmetics"
  ],
  "author": "Chi Fragrance",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/chi-fragrance/scentxury-backend.git"
  },
  "bugs": {
    "url": "https://github.com/chi-fragrance/scentxury-backend/issues"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "@onesignal/node-onesignal": "^5.3.1-beta1",
    "@sentry/node": "^10.32.1",
    "@sentry/tracing": "^7.120.4",
    "axios": "^1.13.2",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.66.4",
    "cloudinary": "^2.8.0",
    "compression": "^1.8.0",
    "cors": "^2.8.5",
    "cron": "^4.3.0",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.5.0",
    "express-session": "^1.18.2",
    "google-auth-library": "^10.5.0",
    "google-spreadsheet": "^5.0.2",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.8.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.0.2",
    "multer": "^2.0.2",
    "nodemailer": "^7.0.5",
    "passport": "^0.7.0",
    "passport-apple": "^2.0.2",
    "passport-google-oauth20": "^2.0.0",
    "paystack-sdk": "^3.6.1",
    "qrcode": "^1.5.4",
    "sharp": "^0.33.5",
    "socket.io": "^4.8.3",
    "stripe": "^20.1.0",
    "winston": "^3.19.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.19",
    "@types/cron": "^2.4.3",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/hpp": "^0.2.6",
    "@types/ioredis-mock": "^8.2.7",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.0.3",
    "@types/nodemailer": "^6.4.17",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/qrcode": "^1.5.5",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "eslint": "^9.27.0",
    "husky": "^9.1.7",
    "ioredis-mock": "^8.13.1",
    "lint-staged": "^16.1.0",
    "mongodb-memory-server": "^10.4.0",
    "prettier": "^3.5.3",
    "supertest": "^7.1.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.15",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
